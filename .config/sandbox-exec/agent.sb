    (home-subpath "/.config/claude")            ;; Claude XDG config.
    (home-subpath "/.local/state/claude")       ;; Claude XDG state.
    (home-subpath "/.local/share/claude")       ;; Claude XDG data (versions, binaries).
    (home-literal "/.mcp.json")                 ;; MCP server configuration file.
)

(allow file-read*
    (home-prefix "/.claude.json.")              ;; Claude config JSON dot-variants.
    (home-literal "/Library/Application Support/Claude/claude_desktop_config.json")  ;; Claude Desktop MCP import source.
    (subpath "/Library/Application Support/ClaudeCode/.claude")       ;; Managed Claude config.
    (literal "/Library/Application Support/ClaudeCode/managed-settings.json")  ;; Managed settings payload.
    (literal "/Library/Application Support/ClaudeCode/managed-mcp.json")       ;; Managed MCP payload.
    (literal "/Library/Application Support/ClaudeCode/CLAUDE.md")              ;; Managed guidance file.
)

