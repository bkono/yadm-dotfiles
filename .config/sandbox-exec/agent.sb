(allow file-read* file-write*
    (home-prefix "/.local/bin/agent")           ;; cursor-agent install/update symlink.
    (home-prefix "/.local/bin/cursor-agent")    ;; cursor-agent binary symlink.
    (home-prefix "/.local/bin/cursor")          ;; cursor CLI shim.
