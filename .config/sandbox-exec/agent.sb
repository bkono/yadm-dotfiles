    (subpath "/Library/Application Support/GeminiCli")  ;; Enterprise managed settings.
)

;; ---------------------------------------------------------------------------
;; Static Project Directory Grants
;; Hardcoded project directories from user configuration.
;; ---------------------------------------------------------------------------

;; Generated ancestor directory literals for ~/src
;;
;; Why file-read* (not file-read-metadata) with literal (not subpath):
;; Agents (notably Claude Code) call readdir() on every ancestor of the working
;; directory during startup. If only file-read-metadata (stat) is granted, the
;; agent cannot list directory contents, which causes it to blank PATH and break.
;; Using 'literal' (not 'subpath') keeps this safe: it grants read access to the
;; directory entry itself (i.e. listing its immediate children), but does NOT
;; grant recursive read access to files or subdirectories under it.
(allow file-read*
    (literal "/")
    (literal "/Users")
    (literal "/Users/bkonowitz")
    (literal "/Users/bkonowitz/src")
)

;; ~/src: read-write (primary code directory)
(allow file-read* file-write*
    (subpath "/Users/bkonowitz/src")
)

;; Generated ancestor directory literals for ~/pkg
(allow file-read*
    (literal "/")
    (literal "/Users")
    (literal "/Users/bkonowitz")
    (literal "/Users/bkonowitz/pkg")
)

;; ~/pkg: read-only (Go package references)
(allow file-read*
    (subpath "/Users/bkonowitz/pkg")
)

;; ---------------------------------------------------------------------------
;; Dynamic Workdir Block
;; Replaced at runtime by run-sandboxed.sh wrapper script.
;; The __SAFEHOUSE_WORKDIR__ token is substituted with the resolved workdir path.
;; ---------------------------------------------------------------------------

;; __WORKDIR_BLOCK_START__
(allow file-read*
    (literal "__SAFEHOUSE_WORKDIR__")
)
(allow file-read* file-write*
    (subpath "__SAFEHOUSE_WORKDIR__")
)
;; __WORKDIR_BLOCK_END__
